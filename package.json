{
  "name": "suncomputer",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "electron.cjs",

  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://162.141.0.9:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "dist": "electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },

  "build": {
    "appId": "com.suncomputer.app",
    "productName": "SunComputer",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "electron.cjs",
      "node_modules/**/*"
    ],

    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.26.2",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.7",
    "jwt-decode": "^4.0.0",
    "mysql2": "^3.16.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-iconly": "^2.2.10",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.6.0",
    "three": "^0.182.0",
    "xlsx": "^0.18.5"
  },

  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/file-saver": "^2.0.7",
    "@types/html2canvas": "^0.5.35",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.10"
  }
}